# Local development secrets for Cloudflare Workers (wrangler dev).
# Copy to .dev.vars and fill in real values. Never commit .dev.vars.
#
#   cp .dev.vars.example .dev.vars
#
# Production: use `wrangler secret put <NAME> --config wrangler.toml --env production`

BLEUJS_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
